@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Login — VistosFácil</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Inter:wght@400;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{background:linear-gradient(135deg,#1B4F72 0%,#0D2B3E 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;}
.card{background:#fff;border-radius:14px;padding:40px 36px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.25);}
.logo{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:1.3rem;color:#1B4F72;margin-bottom:6px;text-align:center;}
.logo span{color:#1E8449;}
.sub{text-align:center;font-size:.78rem;color:#888;font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.05em;margin-bottom:28px;}
label{display:block;font-family:'IBM Plex Mono',monospace;font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;color:#555;margin-bottom:6px;}
input{width:100%;padding:12px 14px;border:1.5px solid #D0D5DD;border-radius:8px;font-size:1rem;margin-bottom:16px;transition:border-color .15s;}
input:focus{outline:none;border-color:#1B4F72;}
button{width:100%;padding:13px;background:#1B4F72;color:#fff;border:none;border-radius:8px;font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:.8rem;letter-spacing:.05em;cursor:pointer;}
button:hover{background:#2E86C1;}
.error{background:#f8d7da;color:#721c24;padding:10px 14px;border-radius:8px;font-size:.88rem;margin-bottom:16px;}
</style>
</head>
<body>
<div class="card">
  <div class="logo">🛂 Vistos<span>Fácil</span></div>
  <div class="sub">Painel de administração</div>
  @if (ViewBag.Error != null)
  { <div class="error">@ViewBag.Error</div> }
  <form method="post" action="/admin/login">
    @Html.AntiForgeryToken()
    <label for="username">Utilizador</label>
    <input id="username" name="username" type="text" autocomplete="username" required>
    <label for="password">Password</label>
    <input id="password" name="password" type="password" autocomplete="current-password" required>
    <button type="submit">Entrar</button>
  </form>
</div>
</body>
</html>
