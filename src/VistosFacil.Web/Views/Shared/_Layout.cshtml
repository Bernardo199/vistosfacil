<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@(ViewData["Title"] != null ? ViewData["Title"] + " — VistosFácil" : "VistosFácil — O seu guia de imigração em português")</title>
<meta name="description" content="@(ViewData["Description"] ?? "Tudo sobre vistos, autorizações de residência e nacionalidade para a diáspora lusófona — explicado de forma simples.")">
<meta property="og:title" content="@(ViewData["Title"] ?? "VistosFácil")">
<meta property="og:description" content="@(ViewData["Description"] ?? "O seu guia de imigração em português.")">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true">

@if (!string.IsNullOrEmpty(ViewData["GoogleAnalyticsId"]?.ToString()))
{
    var gaId = ViewData["GoogleAnalyticsId"]!.ToString();
    <script async src="https://www.googletagmanager.com/gtag/js?id=@gaId"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','@gaId');</script>
}
</head>
<body>

<div class="top-stripe"></div>

<header>
  <div class="nav">
    <a href="/" class="logo">
      🛂 Vistos<span>Fácil</span>
      <small>O seu guia de imigração</small>
    </a>
    <ul>
      <li><a href="/categoria/vistos-portugal">🇵🇹 Portugal</a></li>
      <li><a href="/categoria/vistos-eua">🇺🇸 EUA</a></li>
      <li><a href="/categoria/vistos-schengen">🇪🇺 Schengen</a></li>
      <li><a href="/categoria/autorizacao-residencia">🏠 Residência</a></li>
      <li><a href="/pesquisa">Pesquisar</a></li>
    </ul>
    <button class="nav-toggle" onclick="document.querySelector('.nav ul').classList.toggle('open')">☰</button>
  </div>
</header>

@RenderBody()

<footer>
  <div class="wrap">
    <div>
      <span class="logo">🛂 VistosFácil</span>
      <p>O guia de imigração em português para a diáspora lusófona — vistos, residência e nacionalidade explicados de forma simples.</p>
    </div>
    <div>
      <h4>Vistos</h4>
      <ul>
        <li><a href="/categoria/vistos-portugal">Portugal</a></li>
        <li><a href="/categoria/vistos-eua">EUA</a></li>
        <li><a href="/categoria/vistos-schengen">Schengen</a></li>
        <li><a href="/categoria/vistos-brasil">Brasil</a></li>
      </ul>
    </div>
    <div>
      <h4>Imigração</h4>
      <ul>
        <li><a href="/categoria/autorizacao-residencia">Autorização de Residência</a></li>
        <li><a href="/categoria/nacionalidade">Nacionalidade</a></li>
      </ul>
    </div>
    <div>
      <h4>Legal</h4>
      <ul>
        <li><a href="/privacidade">Política de Privacidade</a></li>
        <li><a href="/termos">Termos de Utilização</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </div>
  </div>
  <p class="fine">© @DateTime.Now.Year VistosFácil. Conteúdo informativo — verifique sempre as fontes oficiais (SEF, Embaixadas, VFS Global) antes de tomar decisões.</p>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
