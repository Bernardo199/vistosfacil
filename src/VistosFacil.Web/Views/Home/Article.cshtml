@model ArticleViewModel
@{
    ViewData["Title"] = Model.Article.MetaTitle ?? Model.Article.Title;
    ViewData["Description"] = Model.Article.MetaDescription ?? Model.Article.Summary;
    ViewData["GoogleAnalyticsId"] = Model.GoogleAnalyticsId;
}

<main style="padding:48px 0;">
  <div class="wrap" style="max-width:780px;">

    <div style="margin-bottom:8px;">
      <a href="/categoria/@Model.Article.Category?.Slug"
         style="display:inline-block;background:var(--azul-claro);color:#fff;font-family:'IBM Plex Mono',monospace;
                font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;padding:4px 10px;border-radius:4px;
                text-decoration:none;margin-bottom:16px;">
        @Model.Article.Category?.Emoji @Model.Article.Category?.TagLabel
      </a>
    </div>

    <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.1;margin-bottom:16px;color:var(--azul);">
      @Model.Article.Title
    </h1>
    <p style="font-size:1.1rem;color:#555;margin-bottom:8px;">@Model.Article.Summary</p>
    <p style="font-family:'IBM Plex Mono',monospace;font-size:.75rem;color:#999;margin-bottom:28px;">
      @Model.Article.CreatedAt.ToString("d 'de' MMMM 'de' yyyy") · @Model.Article.ViewCount visualizações
    </p>

    @if (!string.IsNullOrEmpty(Model.Article.ImageUrl))
    {
        <img src="@Model.Article.ImageUrl" alt="@Model.Article.Title"
             style="width:100%;border-radius:12px;margin-bottom:32px;object-fit:cover;max-height:400px;">
    }

    <!-- Caixa de aviso legal -->
    <div style="background:#EBF5FB;border:1px solid #AED6F1;border-radius:8px;padding:14px 18px;
                margin-bottom:28px;font-size:.88rem;color:#1B4F72;">
      ⚠️ <strong>Aviso:</strong> Este guia é informativo. Verifique sempre as informações nas fontes oficiais
      (SEF/AIMA, Embaixadas, VFS Global) antes de tomar decisões.
    </div>

    <div class="ad-slot" style="margin-bottom:28px;">ESPAÇO PUBLICITÁRIO</div>

    <div class="article-body">
      @Html.Raw(Model.Article.Body)
    </div>

    <div style="margin-top:40px;padding-top:24px;border-top:1px solid var(--cinza-2);
                display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
      <a href="/" style="font-family:'IBM Plex Mono',monospace;font-size:.8rem;text-transform:uppercase;
         letter-spacing:.05em;color:var(--azul-claro);">← Voltar aos guias</a>
      <a href="/categoria/@Model.Article.Category?.Slug"
         style="font-family:'IBM Plex Mono',monospace;font-size:.8rem;text-transform:uppercase;
         letter-spacing:.05em;color:var(--verde);">Ver mais em @Model.Article.Category?.Name →</a>
    </div>
  </div>
</main>
